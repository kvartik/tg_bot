BOT_TOKEN=123456:ABC-your-bot-token
# отдельный бот владельца (клубы, приглашение управляющих, статистика)
OWNER_BOT_TOKEN=123456:ABC-owner-bot-token
OWNER_TG_ID=123456789
# пароль Postgres для docker-compose (DATABASE_URL собирается автоматически)
POSTGRES_PASSWORD=change-me
# для запуска без Docker укажите свой URL:
# DATABASE_URL=postgresql+asyncpg://kyberion:kyberion@localhost:5432/kyberion
TZ=Europe/Kyiv
ROUTINE_DEADLINE_MINUTES=60
OVERDUE_REMIND_MINUTES=30
